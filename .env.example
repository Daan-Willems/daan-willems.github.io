# Copy this file to .env and fill in real values.
# .env is gitignored — credentials never leave your machine.
#
# Run scripts that need these with: npm run fetch:socials
# (the npm script auto-loads .env via Node's --env-file flag)

# --- YouTube Data API v3 ---
# Same key you added to GitHub Secrets. Free tier: 10k units/day.
YOUTUBE_API_KEY=
# Optional override — defaults to @daanwillemsautomotive
YOUTUBE_CHANNEL_ID=UC0ubM_L6ISEgqr5SJfI8XTA

# --- TikTok (public profile scrape, no auth) ---
TIKTOK_HANDLE=daanwillemsautomotive

# --- Instagram (public profile scrape, no auth) ---
IG_HANDLE=daanwillemsautomotive
